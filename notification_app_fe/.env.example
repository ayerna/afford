# Campus Notifications Frontend Environment Configuration
# Copy this file to .env.local and fill in the values

# Notification API endpoint (default: http://20.207.122.201/evaluation-service/notifications)
VITE_NOTIFICATION_API_BASE=http://20.207.122.201/evaluation-service/notifications

# Bearer token for API authentication
# Obtain this token from the evaluation service /auth endpoint
VITE_NOTIFICATION_API_TOKEN=your_bearer_token_here
