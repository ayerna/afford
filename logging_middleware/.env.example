# Logging Middleware Configuration

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=text

# Log file path (optional)
LOG_FILE_PATH=./logs/app.log

# Maximum log file size in bytes (default 10MB)
LOG_FILE_MAX_SIZE=10485760

# Number of backup log files to keep (default 5)
LOG_FILE_BACKUP_COUNT=5

# Include request body in logs
LOG_INCLUDE_REQUEST_BODY=false

# Include response body in logs
LOG_INCLUDE_RESPONSE_BODY=false

# Maximum body size to log in bytes (default 1000)
LOG_MAX_BODY_SIZE=1000

# Paths to exclude from logging (comma-separated)
LOG_EXCLUDE_PATHS=/health,/metrics
